<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Mick Jerryme Mhier M Varona | Portfolio</title>

<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@500&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">

<style>
html { scroll-behavior: smooth; }
* { margin:0; padding:0; box-sizing:border-box; }
body { font-family:'Inter',sans-serif; background:#000; color:#fff; }

/* Navbar */
nav{ position:fixed; width:100%; top:0; padding:10px 28px; display:flex; justify-content:space-between; align-items:center; background:#0a0a0a; border-bottom:1px solid #1a1a1a; z-index:1000; }
nav h1{ font-family:'Orbitron',sans-serif; font-size:15px; }
nav ul{ list-style:none; display:flex; gap:16px; }
nav ul li a{ text-decoration:none; font-size:12px; color:#bbb; }
nav ul li a:hover{ color:#fff; }

/* Sections */
section{ padding:90px 28px 40px; max-width:850px; margin:auto; }
h2{ font-family:'Orbitron',sans-serif; font-size:17px; margin-bottom:12px; }

/* Hero */
.hero{ padding-top:110px; }
.hero h2{ font-size:20px; }

/* About Cards */
.container{ display:grid; grid-template-columns:repeat(auto-fit,minmax(200px,1fr)); gap:10px; }
.card{ background:#0f0f0f; padding:14px; border-radius:6px; border:1px solid #1f1f1f; }
.card h3{ font-size:13px; margin-bottom:5px; }
.card p{ font-size:11px; color:#aaa; }

/* Academic Section */
.academic-box{ background:#0d0d0d; padding:16px; border-radius:8px; border:1px solid #1f1f1f; }
details{ background:#121212; margin-bottom:10px; padding:10px; border-radius:6px; border:1px solid #1f1f1f; }
summary{ font-size:13px; font-weight:500; cursor:pointer; }
.content-area{ margin-top:8px; font-size:11px; color:#aaa; line-height:1.6; min-height:60px; border:1px dashed #333; padding:8px; border-radius:6px; }
.content-area.dragover{ border:2px dashed #fff; }
.content-area img{ max-width:100%; margin-top:8px; border-radius:6px; border:1px solid #222; }

/* Footer */
footer{ text-align:center; padding:10px; font-size:11px; color:#666; border-top:1px solid #1a1a1a; margin-top:25px; }

@media(max-width:600px){
  nav{padding:10px 15px;}
  section{padding:80px 15px 30px;}
}
</style>
</head>
<body>

<nav>
  <h1>Mick Varona</h1>
  <ul>
    <li><a href="#home">Home</a></li>
    <li><a href="#about">About</a></li>
    <li><a href="#academics">Academics</a></li>
  </ul>
</nav>

<section id="home" class="hero">
  <h2>Hello, I'm Mick Jerryme Mhier M Varona</h2>
</section>

<section id="about">
  <h2>About Me</h2>
  <div class="container">
    <div class="card">
      <h3>Skills</h3>
      <p>HTML, CSS and layout design.</p>
    </div>
    <div class="card">
      <h3>Interests</h3>
      <p>Basketball, learning new things, and technology.</p>
    </div>
    <div class="card">
      <h3>Goal</h3>
      <p>To finish college.</p>
    </div>
  </div>
</section>

<section id="academics">
  <h2>Academic Works</h2>
  <div class="academic-box">

    <details>
      <summary>Quizzes</summary>
      <div class="content-area" contenteditable="true">Add your quiz descriptions here. Drag and drop images below:</div>
    </details>

    <details>
      <summary>Activities</summary>
      <div class="content-area" contenteditable="true">Add your activities here. Drag and drop images below:</div>
    </details>

    <details>
      <summary>Exams</summary>
      <div class="content-area" contenteditable="true">Add your exam details here. Drag and drop images below:</div>
    </details>

  </div>
</section>

<footer>
  © 2026 Mick Jerryme Mhier M Varona | BSCS-1D
</footer>

<script>
// Drag & drop image upload
document.querySelectorAll('.content-area').forEach(area => {

  area.addEventListener('dragover', e => {
    e.preventDefault();
    area.classList.add('dragover');
  });

  area.addEventListener('dragleave', e => {
    e.preventDefault();
    area.classList.remove('dragover');
  });

  area.addEventListener('drop', e => {
    e.preventDefault();
    area.classList.remove('dragover');

    const files = e.dataTransfer.files;
    for(let file of files){
      if(file.type.startsWith('image/')){
        const reader = new FileReader();
        reader.onload = function(ev){
          const img = document.createElement('img');
          img.src = ev.target.result;
          area.appendChild(img);
        }
        reader.readAsDataURL(file);
      }
    }
  });

});
</script>

</body>
</html>
