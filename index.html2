<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Simple Calculator</title>
    <style>
        body { 
            font-family: sans-serif; 
            display: flex; 
            justify-content: center; 
            align-items: center; 
            height: 100vh; 
            margin: 0; 
            background-color: #f0f2f5; 
            transition: 0.3s;
        }

        .calc-card {
            background: white;
            padding: 30px;
            border-radius: 15px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
            text-align: center;
            width: 280px;
        }

        input { 
            width: 90%; 
            padding: 12px; 
            margin: 10px 0; 
            border: 1px solid #ccc; 
            border-radius: 8px; 
            font-size: 16px;
            box-sizing: border-box;
        }

        .btn-group { 
            display: grid; 
            grid-template-columns: 1fr 1fr; 
            gap: 10px; 
            margin-top: 10px; 
        }

        button { 
            padding: 12px; 
            cursor: pointer; 
            border: none; 
            border-radius: 8px; 
            background: #007bff; 
            color: white; 
            font-size: 18px; 
            font-weight: bold;
        }

        button:active { transform: scale(0.95); }

        #res { 
            margin-top: 20px; 
            font-size: 22px; 
            color: #333; 
            padding-top: 15px;
            border-top: 1px solid #eee;
        }

        .theme-btn {
            background: #6c757d;
            margin-top: 20px;
            width: 100%;
            font-size: 12px;
            padding: 8px;
        }
    </style>
</head>
<body>

    <div class="calc-card">
        <h2 style="margin: 0 0 15px 0;">Calculator</h2>
        
        <input type="number" id="n1" placeholder="First Number">
        <input type="number" id="n2" placeholder="Second Number">
        
        <div class="btn-group">
            <button onclick="calc('+')">+</button>
            <button onclick="calc('-')">-</button>
            <button onclick="calc('*')">×</button>
            <button onclick="calc('/')">÷</button>
        </div>
        
        <h3 id="res">Result: 0</h3>
        
        <button class="theme-btn" onclick="toggleTheme()">Toggle Dark Mode</button>
    </div>

    <script>
        // THE ALERT LOGIG
        window.addEventListener('offline', () => {
            alert("Status: You are currently OFFLINE!");
        });

        window.addEventListener('online', () => {
            alert("Status: You are back ONLINE!");
        });

        function calc(op) {
            const a = parseFloat(document.getElementById('n1').value);
            const b = parseFloat(document.getElementById('n2').value);
            let r = 0;

            if (isNaN(a) || isNaN(b)) {
                document.getElementById('res').innerText = "Enter numbers!";
                return;
            }

            if (op === '+') r = a + b;
            if (op === '-') r = a - b;
            if (op === '*') r = a * b;
            if (op === '/') r = b !== 0 ? (a / b).toFixed(2) : "Error";

            document.getElementById('res').innerText = "Result: " + r;
        }

        function toggleTheme() {
            const body = document.body;
            if (body.style.backgroundColor === 'rgb(34, 34, 34)') {
                body.style.backgroundColor = '#f0f2f5';
                body.style.color = 'black';
            } else {
                body.style.backgroundColor = '#222';
                body.style.color = 'white';
            }
        }
    </script>
</body>
</html>
